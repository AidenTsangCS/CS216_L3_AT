{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build active file (debug)",
            "command": "/usr/bin/clang++",
            "args": [
                "-std=c++20",
                "-g",
                "-O0",
                "-Wall",
                "-Wextra",
                "-fcolor-diagnostics",
                "${file}",
                "-o",
                "${workspaceFolder}/build/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Compiles the currently open .cpp file with debug symbols"
        }
    ]
}
